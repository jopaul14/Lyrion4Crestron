<?xml version="1.0" encoding="utf-8" ?>
<PairedDeviceUi>
  <DeviceType>MediaPlayer</DeviceType>
  <DisplayName>Lyrion Player</DisplayName>
  <Controls>
    <!-- Transport Controls -->
    <Control>
      <Id>Play</Id>
      <Type>Button</Type>
      <Label>Play</Label>
      <Action>Play</Action>
    </Control>
    <Control>
      <Id>Pause</Id>
      <Type>Button</Type>
      <Label>Pause</Label>
      <Action>Pause</Action>
    </Control>
    <Control>
      <Id>Stop</Id>
      <Type>Button</Type>
      <Label>Stop</Label>
      <Action>Stop</Action>
    </Control>
    <Control>
      <Id>NextTrack</Id>
      <Type>Button</Type>
      <Label>Next Track</Label>
      <Action>NextTrack</Action>
    </Control>
    <Control>
      <Id>PreviousTrack</Id>
      <Type>Button</Type>
      <Label>Previous Track</Label>
      <Action>PreviousTrack</Action>
    </Control>
 
    <!-- Volume Controls -->
    <Control>
      <Id>VolumeUp</Id>
      <Type>Button</Type>
      <Label>Volume Up</Label>
      <Action>VolumeUp</Action>
    </Control>
    <Control>
      <Id>VolumeDown</Id>
      <Type>Button</Type>
      <Label>Volume Down</Label>
      <Action>VolumeDown</Action>
    </Control>
    <Control>
      <Id>VolumeMute</Id>
      <Type>Button</Type>
      <Label>Mute</Label>
      <Action>ToggleMute</Action>
    </Control>
    <Control>
      <Id>VolumeLevel</Id>
      <Type>Slider</Type>
      <Label>Volume</Label>
      <Action>SetVolume</Action>
      <Min>0</Min>
      <Max>100</Max>
    </Control>
 
    <!-- Power Controls -->
    <Control>
      <Id>PowerOn</Id>
      <Type>Button</Type>
      <Label>Power On</Label>
      <Action>PowerOn</Action>
    </Control>
    <Control>
      <Id>PowerOff</Id>
      <Type>Button</Type>
      <Label>Power Off</Label>
      <Action>PowerOff</Action>
    </Control>
 
    <!-- Now Playing Feedback -->
    <Control>
      <Id>NowPlayingTitle</Id>
      <Type>Label</Type>
      <Label>Title</Label>
      <Feedback>CurrentTitle</Feedback>
    </Control>
    <Control>
      <Id>NowPlayingArtist</Id>
      <Type>Label</Type>
      <Label>Artist</Label>
      <Feedback>CurrentArtist</Feedback>
    </Control>
    <Control>
      <Id>NowPlayingAlbum</Id>
      <Type>Label</Type>
      <Label>Album</Label>
      <Feedback>CurrentAlbum</Feedback>
    </Control>
  </Controls>
</PairedDeviceUi>